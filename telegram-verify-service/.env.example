# ─────────────────────────────────────────────────────────────
#  Telegram Verify Service — environment configuration
#  Copy this file to ".env" and fill in the values.
# ─────────────────────────────────────────────────────────────

# HTTP port the service listens on
PORT=8787

# Telegram Gateway API access token.
# Get it from https://gateway.telegram.org → account settings → API token.
TELEGRAM_GATEWAY_TOKEN=

# Comma-separated list of API keys that CLIENT PROJECTS must send in the
# "x-api-key" header. Give each project its own key so you can revoke one
# without breaking the others. Generate with: openssl rand -hex 32
API_KEYS=changeme-generate-a-strong-key

# ── Code / verification settings ──────────────────────────────
# Length of the code Telegram generates (4–8).
CODE_LENGTH=6
# How long (seconds) a code stays valid for verification on our side (30–3600).
CODE_TTL_SECONDS=300
# Max wrong attempts before a code is locked.
MAX_VERIFY_ATTEMPTS=5

# ── Rate limiting (anti-abuse) ────────────────────────────────
# Minimum gap (seconds) between two sends to the same phone.
SEND_COOLDOWN_SECONDS=60
# Max sends to one phone within SEND_WINDOW_SECONDS.
MAX_SENDS_PER_WINDOW=5
SEND_WINDOW_SECONDS=3600
# Max send requests per client IP per minute.
IP_RATE_LIMIT_PER_MIN=30

# ── Telegram options ──────────────────────────────────────────
# If true, we call checkSendAbility first (free) to confirm the number has
# Telegram and to make the actual send free of charge. Recommended.
CHECK_SEND_ABILITY=true
# Optional: verified channel username the code is "sent from" (without @).
SENDER_USERNAME=
# Delivery TTL passed to Telegram (30–3600). Fee is refunded if not delivered
# within this time. Leave empty to omit.
DELIVERY_TTL_SECONDS=

# ── Phone normalization ───────────────────────────────────────
# Default country calling code (digits only, no +) used when a caller passes a
# local number without a country code. Example: 998 for Uzbekistan. Optional.
DEFAULT_COUNTRY_CODE=998

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins for browser callers. Use * to allow all,
# or leave empty to disable CORS (server-to-server only). Example:
# CORS_ORIGINS=https://myapp.com,https://admin.myapp.com
CORS_ORIGINS=

# Environment label (development | production)
NODE_ENV=development
