# =====================================================================
# OnlineTalim — environment variables (TEMPLATE)
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# =====================================================================

# --- Supabase: PUBLIC values (safe in the browser, shipped in the bundle) ---
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJ...anon-key..."
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ...anon-key..."

# --- Supabase: SECRET (server-only, bypasses RLS). NEVER add a VITE_ prefix. ---
SUPABASE_SERVICE_ROLE_KEY="eyJ...service-role-key..."

# --- Telegram Verify Service (server-only OTP) ---
VERIFY_BASE_URL="https://your-verify-service.example.com"
VERIFY_API_KEY="your-verify-api-key"

# --- Bunny Stream (video hosting, server-only) ---
BUNNY_STREAM_LIBRARY_ID="000000"
BUNNY_STREAM_API_KEY="your-bunny-api-key"
BUNNY_STREAM_TOKEN_KEY="your-bunny-token-auth-key"

# --- Public site URL (used for canonical URLs / SEO). Set in production. ---
VITE_SITE_URL="https://onlinetalim.uz"
